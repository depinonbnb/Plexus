# ── Plexus settlement layer env ──
# Copy to .env and fill in. Secrets (keys) must NEVER be committed.

# Network: 'mainnet' (BSC) or 'testnet' (BSC testnet)
PLEXUS_NETWORK=testnet
BSC_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545

# Stablecoin + DEX (BSC mainnet defaults shown; override on testnet)
USDC_ADDRESS=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d
USDC_DECIMALS=18
PANCAKE_ROUTER=0x10ED43C718714eb63d5aA57B78B54704E256024E

# Plexus contracts (set after `forge script Deploy`)
PLEX_TOKEN_ADDRESS=
STAKING_ADDRESS=
REWARD_DISTRIBUTOR_ADDRESS=
BUYBACK_ADDRESS=
STAKING_DEPLOY_BLOCK=0

# Server-held keys (0x-prefixed 32-byte hex). KEEP OFF-REPO.
TREASURY_WALLET_KEY=
KEEPER_WALLET_KEY=
# AES-256 key (32-byte hex) used to encrypt per-user custodial deposit wallets.
DEPOSIT_WALLET_KEY=

# Keeper safety: anything other than the literal 'false' = dry run (no money moves).
KEEPER_DRY_RUN=true
BUYBACK_SLIPPAGE_BPS=500
BUYBACK_BUDGET_USD=0
KEEPER_UTC_HOUR=15

# Tokenomics overrides (defaults baked into src/lib/tokenomics.ts)
# COMPUTE_MARGIN_BUYBACK_PCT=1.0
# TRADING_FEE_BUYBACK_PCT=0.35
# POOL_BURN_SPLIT=0.5
# WORKER_STAKED_REVENUE_SHARE=0.8
# WORKER_STAKE_THRESHOLD=500000
